    "db:reset": "npx supabase db reset"
  },
  "dependencies": {
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.2",
    "typescript": "5.9.3"
  }
}
